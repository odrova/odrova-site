</script>

{%- comment -%}
  Новый JS ODROVA: цена в кнопке «Купить — Х ₽» и сумма в плашке «онлайн −10%».
  Без привязки к событиям темы: MutationObserver следит за блоком цены,
  поэтому работает при любой смене варианта.
{%- endcomment -%}
<script>
  $(function () {
    try {
      var $price = $('.od-product .js-product-price').first();
      if (!$price.length) $price = $('.od-product .product-prices .price').first();
      var $btn = $('.od-product button[data-item-add]').first();

      function parsePrice(text) {
        var n = (text || '').replace(/[^\d.,]/g, '').replace(/\s/g, '').replace(',', '.');
        return parseFloat(n) || 0;
      }
      function fmt(n) {
        return Math.round(n).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '\u202F') + '\u00A0₽';
      }
      // пишем текст ТОЛЬКО если он изменился — иначе наблюдатель будит сам себя
      function setText($el, val) {
        if ($el.length && $el.text() !== val) $el.text(val);
      }
      function setHtml($el, val) {
        if ($el.length && $el.html() !== val) $el.html(val);
      }

      // покупка разблокируется после ЯВНОГО выбора диаметра покупателем
      var odChosen = false;

      function syncAll() {
        try {
          var p = parsePrice($price.text());
          if (!p) return;
          // данные выбранного варианта
          var dia = $('.od-product .option-value.is-active.is-diametr .diametr-text').first().text().trim();
          var $thrBtn = $('.od-product .is-span .option-value.is-active').first();
          var thread = ($thrBtn.find('.od-span-main').text() || $thrBtn.text()).trim().split('—')[0].trim();
          var meta = window.odProductMeta || {};
          // богатая кнопка: Купить / Ø.. / L.. / посадка .. / цена + строка резьбы
          if ($btn.length) {
            var $bt = $btn.find('.button-text');
            if (!$bt.length) $bt = $btn;
            if (odChosen) {
              var parts = ['Купить'];
              if (meta.d) parts.push('Ø' + meta.d);
              if (meta.l) parts.push('L' + meta.l);
              if (dia) parts.push('посадка ' + dia);
              parts.push(fmt(p * 0.9));
              var line2 = thread ? '<span class="od-buy-line2">' + thread + ' резьба</span>' : '';
              setHtml($bt, '<span class="od-buy-line1">' + parts.join(' / ') + '</span>' + line2);
              $btn.removeClass('od-buy-waiting');
            } else {
              setHtml($bt, '<span class="od-buy-line1">Выберите диаметр вала \u2191</span>');
              $btn.addClass('od-buy-waiting');
            }
          }
          // сумма в плашке «онлайн −10%»
          setText($('.js-od-online-price'), fmt(p * 0.9));
          // обычная цена (полная) в строке «Обычная цена: N ₽»
          setText($('.js-od-regular-price'), fmt(p));
          // липкая панель: цена и онлайн-цена
          setText($('.js-od-sticky-price'), fmt(p));
          setText($('.js-od-sticky-online'), 'онлайн ' + fmt(p * 0.9));
          // статус наличия: «Под Заказ» в названии варианта или кнопка предзаказа темы
          var vTitle = $('.od-product select[data-product-variants] option:selected').text() || '';
          var preorderShown = /под\s*заказ/i.test(vTitle) || $('.od-product .js-variant-preorder').is(':visible');
          // текст отправки по времени Екатеринбурга (UTC+5), сб/вс — выходные
          function odShipText() {
            var now = new Date();
            var ekb = new Date(now.getTime() + now.getTimezoneOffset() * 60000 + 5 * 3600000);
            var day = ekb.getDay(); // 0 вс ... 6 сб
            if (day === 0 || day === 6) return 'отправка в понедельник';
            if (ekb.getHours() < 16) return 'отправка сегодня до 16:00';
            return (day === 5) ? 'отправка в понедельник' : 'отправка завтра';
          }
          var $av = $('.js-od-availability');
          if (preorderShown) {
            setText($av, 'Под заказ · изготовим за 3–7 дней');
            $av.addClass('is-preorder');
          } else {
            setText($av, 'В наличии · ' + odShipText());
            $av.removeClass('is-preorder');
          }
          // красный бейдж «−X%»
          var oldP = parsePrice($('.od-product .js-product-old-price').first().text());
          if (oldP > p) {
            var $b = $('.js-od-sale-badge');
            if (!$b.length) $b = $('<span class="js-od-sale-badge od-sale-badge"></span>').insertAfter($price);
            setText($b, '−' + Math.round((1 - p / oldP) * 100) + '%');
          } else {
            $('.js-od-sale-badge').remove();
          }
        } catch (e) { /* не роняем скрипты темы */ }
      }

      if ($price.length) {
        // строка наличия — сразу под рядом цены
        var $prices = $price.closest('.product-prices');
        if ($prices.length) $('.js-od-availability').insertAfter($prices);

        // плашка «онлайн −10%» — сразу под наличием (как в прототипе, до выбора вала).
        // Кладём в форму после наличия и даём flex-order между ценой и вариантами.
        var $avEl = $('.js-od-availability').first();
        if ($avEl.length) {
          // DOM-порядок: цена → плашка → обычная цена → наличие.
          // Всем order:2 (как у цены) — внутри одного order выстроятся по DOM.
          $('.od-online-badge').insertAfter($avEl);                  // плашка после наличия...
          $('.od-online-note').insertAfter($('.od-online-badge'));   // обычная цена за плашкой
          $avEl.insertAfter($('.od-online-note'));                   // наличие — в самый низ ряда
          $('.od-online-badge').get(0).style.setProperty('order', '2', 'important');
          var $oNote = $('.od-online-note').get(0);
          if ($oNote) $oNote.style.setProperty('order', '2', 'important');
          $avEl.get(0).style.setProperty('order', '2', 'important');
        } else {
          // запасной путь: перед кнопкой
          var $buyRow = $btn.closest('.main-controls');
          if (!$buyRow.length) $buyRow = $btn.parent();
          $('.od-online-note').insertBefore($buyRow);
          $('.od-online-badge').insertBefore($('.od-online-note'));
        }

        // Категории: выносим готовый блок темы ИЗ ФОРМЫ под галерею.
        // Двигаем существующий узел наружу формы — клонирования не будет.
        var $cats = $('.product-collections').first();
        var $gal  = $('.od-product__gallery').first();
        if ($cats.length && $gal.length && !$cats.hasClass('od-cats-moved')) {
          $cats.addClass('od-cats-moved');
          $gal.append($cats);
        }

        // липкая мобильная панель покупки
        var $bar = $('<div class="od-sticky-buy">' +
          '<div class="od-sticky-buy__prices"><b class="js-od-sticky-price"></b>' +
          '<span class="js-od-sticky-online"></span></div>' +
          '<button type="button" class="od-sticky-buy__btn">Купить</button></div>').appendTo('body');
        $bar.find('.od-sticky-buy__btn').on('click', function () {
          if ($btn.is(':visible')) { $btn.trigger('click'); }
          else { $('html,body').animate({ scrollTop: $('.od-product').offset().top }, 300); }
        });

        // --- мобильная галерея: главный кадр — наш .od-mobile-main;
        //     родной .gallery-main-wrapper прячем (иначе двоится) ---
        if (window.matchMedia('(max-width: 760px)').matches) {
          var odMw = document.querySelector('.od-product-page .gallery-main-wrapper');
          if (odMw) odMw.style.setProperty('display', 'none', 'important');
        }

        // --- состояние «Выберите диаметр»: до явного клика покупка заблокирована ---
        $('.od-product').addClass('od-not-chosen');
        $(document).on('click', '.od-product .option-value.is-diametr', function () {
          if (!odChosen) {
            odChosen = true;
            $('.od-product').removeClass('od-not-chosen');
          }
          setTimeout(syncAll, 50);
        });
        // попытка купить без выбора — не отправляем, ведём к диаметрам
        $('.od-product form.product-form').on('submit', function (e) {
          if (!odChosen) {
            e.preventDefault();
            var $opt = $('.od-product div.is-diametr').first();
            if ($opt.length) {
              $('html,body').animate({ scrollTop: $opt.offset().top - 90 }, 250);
              $opt.addClass('od-flash');
              setTimeout(function () { $opt.removeClass('od-flash'); }, 1200);
            }
            return false;
          }
        });

        syncAll();
        // наблюдаем за обёрткой цен; setText с проверкой исключает зацикливание
        var target = $price.closest('.product-prices').get(0) || $price.get(0);
        new MutationObserver(syncAll).observe(target, { childList: true, subtree: true, characterData: true });
        // статус наличия зависит от выбранного варианта — следим за переключателем кнопок темы
        var $preorder = $('.od-product .js-variant-preorder').first();
        if ($preorder.length) {
          new MutationObserver(syncAll).observe($preorder.get(0), { attributes: true, attributeFilter: ['style'] });
        }
        // цена у вариантов может совпадать — ловим смену варианта по селекту и артикулу
        $(document).on('change', '.od-product select[data-product-variants]', function () { setTimeout(syncAll, 50); });
        var $sku = $('.od-product .js-product-sku').first();
        if ($sku.length) {
          new MutationObserver(syncAll).observe($sku.get(0), { childList: true, subtree: true, characterData: true });
        }
      }
    } catch (e) { /* не роняем скрипты темы */ }
  });
</script>

