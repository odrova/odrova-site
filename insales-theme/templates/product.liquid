<script type="text/javascript">
  $( document ).ready(function() {
    $('.review-manager_reply').each(function() {
      var text = $( this ).text();
      var link; var link_text;
      if (text.includes('http')) {
        if (text.includes('youtu')) {
          var utID = text.split('/').pop();
          link = '<iframe src="//www.youtube.com/embed/'+utID+'" width="560" height="314" allowfullscreen="allowfullscreen"></iframe>'
          link_text = text.split('https://')[0]+link
          $( this ).html(link_text);
        } else {
          link = '<a href="http://'+text.split('://').pop().trim()+'">'+text.split('://').pop().trim()+'</a>'
          link_text = text.split('://')[0].replace("http", "").replace("https", "")+link;
          $( this ).html(link_text);
        }
      }
    });
  });
</script>

<script>
  // Клик по строке рейтинга «★ … · читать» — открыть вкладку «Отзывы» и плавно доскроллить.
  // Якоря #od-reviews-tab в табах нет (сниппет темы не трогаем) — находим вкладку по тексту
  // «Отзыв» среди заголовков табов (.tab-toggle / [data-tab]) и кликаем её.
  $(function () {
    // СТРАХОВКА: InSales кэширует скомпилированный SCSS и не всегда подхватывает
    // правки custom.scss. Чтобы строка рейтинга гарантированно выглядела как нужно,
    // проставляем ВСЕ её стили инлайном на элементы — минуя компиляцию CSS.
    function odIsMobile() { return window.matchMedia('(max-width: 760px)').matches; }
    function odStyleRating() {
      var $rl = $('.js-od-rating-line').first();
      if (!$rl.length) return;
      var mob = odIsMobile();
      // размеры: десктоп крупные, мобила мельче (иначе строка вылезает за экран)
      var starsF = mob ? '1.25rem' : '1.75rem';
      var starsM = mob ? '8px'     : '14px';
      var avgF   = mob ? '1.1rem'  : '1.55rem';
      var sepF   = mob ? '0.9rem'  : '1.15rem';
      var sepM   = mob ? '0 9px'   : '0 16px';
      var txtF   = mob ? '0.95rem' : '1.2rem';
      // на мобиле разрешаем перенос (nowrap убираем), чтобы не вылезало
      $rl.css({
        'display': 'block', 'margin-top': mob ? '14px' : '20px',
        'margin-bottom': mob ? '18px' : '28px',
        'line-height': '1.4', 'white-space': mob ? 'normal' : 'nowrap',
        'text-decoration': 'none', 'font-family': "'PT Sans', sans-serif", 'cursor': 'pointer'
      });
      $rl.children().css({ 'display': 'inline-block', 'vertical-align': 'middle' });
      var starsEl = $rl.find('.od-rating-line__stars').get(0);
      if (starsEl) {
        starsEl.style.setProperty('font-size', starsF, 'important');
        starsEl.style.setProperty('letter-spacing', mob ? '2px' : '3px', 'important');
        starsEl.style.setProperty('color', '#f5c800', 'important');
        starsEl.style.setProperty('-webkit-text-fill-color', '#f5c800', 'important');
        starsEl.style.setProperty('margin-right', starsM, 'important');
      }
      var avgEl = $rl.find('.od-rating-line__avg').get(0);
      if (avgEl) {
        avgEl.style.setProperty('font-size', avgF, 'important');
        avgEl.style.setProperty('font-weight', '700', 'important');
        avgEl.style.setProperty('color', '#111', 'important');
        avgEl.style.setProperty('-webkit-text-fill-color', '#111', 'important');
        avgEl.style.setProperty('line-height', '1', 'important');
      }
      $rl.find('.od-rating-line__sep').css({ 'color': '#c4c4c4', 'font-size': sepF, 'margin': sepM });
      $rl.find('.od-rating-line__count').css({ 'font-size': txtF, 'color': '#555' });
      $rl.find('.od-rating-line__read').css({
        'font-size': txtF, 'font-weight': '700', 'color': '#555', 'border-bottom': '1px solid #999'
      });
    }
    // вызываем несколько раз: тема может перекрашивать звёзды своим JS позже загрузки
    odStyleRating();
    setTimeout(odStyleRating, 300);
    setTimeout(odStyleRating, 800);

    // черта под чипами характеристик (как в прототипе) — серая разделительная линия.
    // Ставим инлайном, т.к. CSS может не доехать из-за кэша компиляции SCSS.
    function odChipsRule() {
      var mob = odIsMobile();
      var chips = document.querySelector('.od-product-page .od-spec-tags');
      if (chips) {
        chips.style.setProperty('padding-bottom', mob ? '14px' : '20px', 'important');
        chips.style.setProperty('border-bottom', '1px solid #e0e0e0', 'important');
        chips.style.setProperty('margin-bottom', mob ? '14px' : '20px', 'important');
        chips.style.setProperty('gap', mob ? '7px' : '12px', 'important');
        chips.querySelectorAll('.od-spec-tag').forEach(function (t) {
          t.style.setProperty('font-size', mob ? '0.8rem' : '0.95rem', 'important');
          t.style.setProperty('padding', mob ? '7px 11px' : '11px 17px', 'important');
        });
      }
      var h1 = document.querySelector('.od-product-page .od-product__title');
      if (h1) {
        h1.style.setProperty('font-size', mob ? '1.5rem' : '2.4rem', 'important');
        h1.style.setProperty('line-height', '1.2', 'important');
      }
      var kicker = document.querySelector('.od-product-page .od-kicker');
      if (kicker) {
        kicker.style.setProperty('font-size', mob ? '0.72rem' : '0.82rem', 'important');
        kicker.style.setProperty('letter-spacing', mob ? '2px' : '2.5px', 'important');
      }
    }
    odChipsRule();
    setTimeout(odChipsRule, 300);
    // пересчёт при ресайзе/повороте экрана
    var odRzT;
    $(window).on('resize orientationchange', function () {
      clearTimeout(odRzT);
      odRzT = setTimeout(function () { odStyleRating(); odChipsRule(); }, 150);
    });
    $(document).on('click', '.js-od-rating-line', function (e) {
      e.preventDefault();
      var $tab = $('.od-product-page .tab-toggle, .od-product-page [data-tab], .od-product-page .tabs-controls a, .od-product-page .tabs-controls button')
        .filter(function () { return /отзыв/i.test($(this).text()); }).first();
      if ($tab.length) {
        $tab.trigger('click');
        $('html,body').animate({ scrollTop: $tab.offset().top - 90 }, 350);
      } else {
        // запасной путь: проскроллить к блоку отзывов, если он на странице
        var $rev = $('.od-product-page .reviews, .od-product-page .product-reviews, .od-product-page .comment_list').first();
        if ($rev.length) $('html,body').animate({ scrollTop: $rev.offset().top - 90 }, 350);
      }
    });
  });
</script>

<script>
  (function () {
    function set(el, prop, value) {
      if (!el) return;
      if (el.style.getPropertyValue(prop) === String(value) && el.style.getPropertyPriority(prop) === 'important') return;
      el.style.setProperty(prop, value, 'important');
    }

    function placeAfter(node, anchor) {
      if (!node || !anchor || !anchor.parentNode) return;
      if (node.parentNode === anchor.parentNode && anchor.nextSibling === node) return;
      anchor.parentNode.insertBefore(node, anchor.nextSibling);
    }

    function odLockSupportBlocks() {
      var info = document.querySelector('.od-product-page .od-product__info');
      var form = document.querySelector('.od-product-page .od-product__info form.product-form');
      var sku = form && form.querySelector('.product-sku-wrapper');
      var prices = form && form.querySelector('.product-prices');
      var selectors = form && form.querySelector('.product-option-selectors');
      var reviewLink = form && form.querySelector('.review-link, .reviews-link, .js-review-link, .js-reviews-link');
      var control = form && form.querySelector('.product-control');
      var collections = form && form.querySelector('.product-collections');
      var controls = document.querySelector('.od-product-page .main-controls');
      var onlineBadge = document.querySelector('.od-product-page .od-online-badge');
      var onlineNote = document.querySelector('.od-product-page .od-online-note');
      var availability = document.querySelector('.od-product-page .js-od-availability');
      var ask = document.querySelector('.od-product-page .od-ask');
      var askLink = document.querySelector('.od-product-page .od-ask__link');
      var askHint = document.querySelector('.od-product-page .od-ask__hint');
      var messengers = document.querySelector('.od-product-page .od-messengers');
      var delivery = document.querySelector('.od-product-page .od-delivery');
      var tiles = document.querySelector('.od-product-page .od-tiles');
      var tabBlock = document.querySelector('.od-product-page .product-content.tab');

      if (form && prices) {
        placeAfter(onlineBadge, prices);
        placeAfter(onlineNote, onlineBadge || prices);
        placeAfter(availability, onlineNote || onlineBadge || prices);
      }

      if (info && form) {
        placeAfter(ask, form);
        placeAfter(delivery, ask || form);
        placeAfter(tiles, delivery || ask || form);
      }

      set(form, 'display', 'flex');
      set(form, 'flex-direction', 'column');
      set(form, 'gap', '0');
      set(form, 'margin-bottom', '0');
      set(sku, 'order', '1');
      set(prices, 'order', '2');
      set(onlineBadge, 'order', '3');
      set(onlineNote, 'order', '4');
      set(availability, 'order', '5');
      set(selectors, 'order', '6');
      set(reviewLink, 'order', '7');
      set(control, 'order', '8');
      set(collections, 'order', '9');
      set(control, 'margin-top', '0');
      set(control, 'margin-bottom', '0');
      set(control, 'padding-bottom', '0');
      set(controls, 'margin-top', '-8px');
      set(controls, 'margin-bottom', '0');
      set(tabBlock, 'margin-top', '18px');

      document.querySelectorAll('.od-product-page .main-controls .product-button.is-primary').forEach(function (el) {
        set(el, 'min-height', '108px');
        set(el, 'padding', '18px 24px');
      });

      if (ask) {
        set(ask, 'margin', '-18px 0 8px');
        set(ask, 'padding', '12px 14px');
        set(ask, 'background', '#fff');
        set(ask, 'border', '1px solid #d8dde4');
        set(ask, 'box-shadow', '0 1px 0 rgba(17,17,17,0.03)');
      }

      if (askLink) {
        set(askLink, 'display', 'block');
        set(askLink, 'margin', '0 0 7px');
        set(askLink, 'padding', '0');
        set(askLink, 'border', '0');
        set(askLink, 'background', 'transparent');
        set(askLink, 'color', '#111');
        set(askLink, 'font-size', '16px');
        set(askLink, 'line-height', '20px');
        set(askLink, 'font-weight', '800');
        set(askLink, 'text-align', 'left');
      }

      if (askHint) {
        set(askHint, 'display', 'block');
        set(askHint, 'margin', '7px 0 0');
        set(askHint, 'color', '#7a828d');
        set(askHint, 'font-size', '12px');
        set(askHint, 'line-height', '16px');
        set(askHint, 'text-align', 'left');
      }

      if (messengers) {
        set(messengers, 'display', 'grid');
        set(messengers, 'grid-template-columns', 'repeat(3, 1fr)');
        set(messengers, 'gap', '7px');
      }

      document.querySelectorAll('.od-product-page .od-msg').forEach(function (el) {
        set(el, 'display', 'flex');
        set(el, 'align-items', 'center');
        set(el, 'justify-content', 'center');
        set(el, 'min-height', '34px');
        set(el, 'padding', '0 12px');
        set(el, 'color', '#fff');
        set(el, 'font-size', '13px');
        set(el, 'line-height', '1');
        set(el, 'font-weight', '800');
      });

      if (delivery) {
        set(delivery, 'display', 'grid');
        set(delivery, 'grid-template-columns', window.matchMedia('(max-width: 760px)').matches ? 'repeat(2, 1fr)' : (window.matchMedia('(min-width: 1700px)').matches ? 'repeat(6, minmax(0, 1fr))' : 'repeat(3, 1fr)'));
        set(delivery, 'gap', window.matchMedia('(min-width: 1700px)').matches ? '6px' : '8px');
        set(delivery, 'margin', '8px 0 8px');
        set(delivery, 'padding', '0');
        set(delivery, 'background', 'transparent');
        set(delivery, 'border', '0');
      }

      document.querySelectorAll('.od-product-page .od-delivery__item').forEach(function (el) {
        set(el, 'display', window.matchMedia('(min-width: 1700px)').matches ? 'flex' : 'block');
        set(el, 'align-items', window.matchMedia('(min-width: 1700px)').matches ? 'center' : 'stretch');
        set(el, 'justify-content', window.matchMedia('(min-width: 1700px)').matches ? 'center' : 'flex-start');
        set(el, 'min-height', window.matchMedia('(min-width: 1700px)').matches ? '36px' : '56px');
        set(el, 'padding', window.matchMedia('(min-width: 1700px)').matches ? '7px 8px' : '10px 12px');
        set(el, 'background', '#fff');
        set(el, 'border', '1px solid #d8dde4');
        set(el, 'box-sizing', 'border-box');
      });

      document.querySelectorAll('.od-product-page .od-delivery__item b').forEach(function (el) {
        set(el, 'display', 'block');
        set(el, 'margin', window.matchMedia('(min-width: 1700px)').matches ? '0' : '0 0 3px');
        set(el, 'color', '#111');
        set(el, 'font-size', window.matchMedia('(min-width: 1700px)').matches ? '11px' : '13px');
        set(el, 'line-height', window.matchMedia('(min-width: 1700px)').matches ? '13px' : '15px');
        set(el, 'font-weight', '800');
        set(el, 'text-align', window.matchMedia('(min-width: 1700px)').matches ? 'center' : 'left');
        set(el, 'white-space', window.matchMedia('(min-width: 1700px)').matches ? 'nowrap' : 'normal');
      });

      document.querySelectorAll('.od-product-page .od-delivery__item span').forEach(function (el) {
        set(el, 'display', window.matchMedia('(min-width: 1700px)').matches ? 'none' : 'block');
        set(el, 'color', '#7a828d');
        set(el, 'font-size', '11px');
        set(el, 'line-height', '14px');
      });

      if (tiles) {
        set(tiles, 'display', 'flex');
        set(tiles, 'flex-wrap', 'wrap');
        set(tiles, 'gap', '6px');
        set(tiles, 'margin', '6px 0 0');
      }

      document.querySelectorAll('.od-product-page .od-tile').forEach(function (el) {
        set(el, 'display', 'inline-flex');
        set(el, 'align-items', 'center');
        set(el, 'justify-content', 'center');
        set(el, 'gap', '7px');
        set(el, 'min-height', '30px');
        set(el, 'padding', '6px 10px');
        set(el, 'background', '#fff');
        set(el, 'border', '1px solid #d8dde4');
        set(el, 'color', '#111');
        set(el, 'box-sizing', 'border-box');
        set(el, 'font-size', '11px');
        set(el, 'line-height', '14px');
        set(el, 'font-weight', '800');
        set(el, 'letter-spacing', '0');
      });

      document.querySelectorAll('.od-product-page .od-tile span').forEach(function (el) {
        set(el, 'color', '#111');
      });
    }

    var odLockTimer = null;
    function odScheduleLock() {
      if (odLockTimer) return;
      odLockTimer = setTimeout(function () {
        odLockTimer = null;
        odLockSupportBlocks();
      }, 30);
    }

    odLockSupportBlocks();
    setTimeout(odLockSupportBlocks, 50);
    setTimeout(odLockSupportBlocks, 350);
    setTimeout(odLockSupportBlocks, 900);
    setTimeout(odLockSupportBlocks, 1700);
    setTimeout(odLockSupportBlocks, 3000);
    window.addEventListener('load', odLockSupportBlocks);
    window.addEventListener('resize', odLockSupportBlocks);

    var host = document.querySelector('.od-product-page .od-product__info');
    if (host && window.MutationObserver) {
      new MutationObserver(odScheduleLock).observe(host, { childList: true, subtree: true, attributes: true, attributeFilter: ['style', 'class'] });
    }
  })();
</script>

</div>{%- comment -%} /.od-product-page {%- endcomment -%}
