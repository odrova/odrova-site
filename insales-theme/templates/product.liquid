<script>
  // Снимаем белый фон/рамку/паддинг с контейнера .option-values напрямую
  // (тема красит его в theme.css белым без !important; CSS-перебив капризничал
  // из-за кэша компиляции — инлайн через JS работает гарантированно).
  (function () {
    function odClearOptionBg() {
      document.querySelectorAll('.od-product-page .option-values').forEach(function (el) {
        el.style.setProperty('background', 'transparent', 'important');
        el.style.setProperty('background-color', 'transparent', 'important');
        el.style.setProperty('border', 'none', 'important');
        el.style.setProperty('padding', '0', 'important');
      });
      // контейнер кнопок РЕЗЬБЫ — на всю ширину (две кнопки пополам).
      // Ставим тут же, т.к. инлайн этой функции перебивал CSS-правило.
      document.querySelectorAll('.od-product-page .is-span .option-values').forEach(function (el) {
        el.style.setProperty('display', 'flex', 'important');
        el.style.setProperty('width', '100%', 'important');
        el.style.setProperty('gap', '10px', 'important');
        el.style.setProperty('margin-top', '-4px', 'important');
        el.style.setProperty('margin-bottom', '0', 'important');
      });
      document.querySelectorAll('.od-product-page .product-option.is-span, .od-product-page .option.is-span').forEach(function (el) {
        el.style.setProperty('margin-top', '8px', 'important');
        el.style.setProperty('margin-bottom', '18px', 'important');
        el.style.setProperty('padding-bottom', '0', 'important');
      });
      document.querySelectorAll('.od-product-page .is-span .option-label').forEach(function (el) {
        el.style.setProperty('margin', '0 0 6px', 'important');
        el.style.setProperty('line-height', '12px', 'important');
      });
      document.querySelectorAll('.od-product-page .is-span .option-value.left, .od-product-page .is-span .option-value.right, .od-product-page .option-value.is-span').forEach(function (el) {
        el.style.setProperty('min-height', '48px', 'important');
        el.style.setProperty('padding', '7px 14px', 'important');
      });
    }
    odClearOptionBg();
    setTimeout(odClearOptionBg, 300);   // тема дорисовывает опции своим JS
    setTimeout(odClearOptionBg, 800);
    // на случай перерисовки опций (смена варианта и т.п.)
    var host = document.querySelector('.od-product-page .product-option-selectors, .od-product-page form.product-form');
    if (host && window.MutationObserver) {
      new MutationObserver(odClearOptionBg).observe(host, { childList: true, subtree: true });
    }
  })();
</script>

