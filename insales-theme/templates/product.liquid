{% comment %} ============================================================
  ODROVA — карточка товара под прототип odrova.ru (v1, светлая)
  Механика demo-smart сохранена: product_labels, product_gallery,
  product_form, Products.setConfig + шаблоны опций — без изменений.
  Новое: обёртка .od-product-page (светлая зона), кикер, теги из
  метаполя od-tags, плашка «онлайн −10%», мессенджеры, блок доставки,
  плитки преимуществ, заголовок «Обычно берут вместе».
============================================================ {% endcomment %}

<div class="od-product-page">

{%- comment -%} Крошки рендерим сами (page_header на товаре отключён в layout) {%- endcomment -%}
{% include "breadcrumb", home_title: 'Главная' %}

<div class="row custom-padding od-product">

  {%- comment -%} ===== ЛЕВАЯ КОЛОНКА: фото + плашки ===== {%- endcomment -%}
  <div class="product-gallery-wrapper od-product__gallery cell-6 cell-6-md cell-12-sm">
    {% include "product_labels", product: product %}
    {%- comment -%} Лента-метка из метаполя od-ribbon (напр. «2-ЗАХОДНАЯ РЕЗЬБА») {%- endcomment -%}
    {% if product.fields.od-ribbon.value != blank %}
    <div class="od-ribbon">{{ product.fields.od-ribbon.value }}</div>
    {% endif %}
    {% include "product_gallery" %}
  </div>

  {%- comment -%} ===== ПРАВАЯ КОЛОНКА ===== {%- endcomment -%}
  <div class="od-product__info cell-6 cell-6-md cell-12-sm">

    {%- comment -%} Кикер: категория · ODROVA.RU {%- endcomment -%}
    <div class="od-kicker">
      {%- if product.collections.first -%}
        {{ product.collections.first.title }} · ODROVA.RU
      {%- else -%}
        ODROVA.RU
      {%- endif -%}
    </div>

    <h1 class="od-product__title">{{ product.title }}</h1>

    {%- comment -%}
      Строка рейтинга НАД чипами: «★ 4.9 · N отзывов · читать».
      Средний балл считаем ТОЛЬКО по отзывам с оценкой (rating > 0) — часть
      отзывов InSales без звёзд (вопросы/комментарии), они не должны топить средний.
      Количество показываем общее (product.reviews.size). Нет отзывов — строки нет.
      Клик ведёт на вкладку «Отзывы» ниже (плавный скролл, JS).
    {%- endcomment -%}
    {% if product.reviews.size > 0 %}
      {% assign od_rsum = 0 %}{% assign od_rcnt = 0 %}
      {% for rv in product.reviews %}{% if rv.rating > 0 %}{% assign od_rsum = od_rsum | plus: rv.rating %}{% assign od_rcnt = od_rcnt | plus: 1 %}{% endif %}{% endfor %}
      {% if od_rcnt > 0 %}{% assign od_avg = od_rsum | times: 10 | divided_by: od_rcnt %}{% else %}{% assign od_avg = 0 %}{% endif %}
      <a href="#od-reviews-tab" class="od-rating-line js-od-rating-line">
        <span class="od-rating-line__stars" aria-hidden="true">★★★★★</span>{% if od_avg > 0 %}<b class="od-rating-line__avg">{{ od_avg | divided_by: 10 }}.{{ od_avg | modulo: 10 }}</b>{% endif %}<span class="od-rating-line__sep">·</span><span class="od-rating-line__count">{{ product.reviews.size }}&nbsp;{% if product.reviews.size == 1 %}отзыв{% elsif product.reviews.size >= 2 and product.reviews.size <= 4 %}отзыва{% else %}отзывов{% endif %}</span><span class="od-rating-line__sep">·</span><span class="od-rating-line__read">читать</span>
      </a>
    {% endif %}

    {%- comment -%}
      Теги-характеристики из метаполя товара «od_tags» (пермалинк с подчёркиванием).
      Формат значения: ⌀ 75 мм; L 300 мм; 2 захода; 17.5° угол; Ст45 + ТВЧ; 24–28 HRC; 4.9 кг; от 2.2 кВт
      У комплектующих — свои теги, у станков — свои. Нет метаполя — блок не выводится.
    {%- endcomment -%}
    {% if product.fields.od_tags.value != blank %}
    <div class="od-spec-tags">
      {% assign od_tags_raw = product.fields.od_tags.value | strip_html | strip_newlines | split: ';' %}
      {% for t in od_tags_raw %}{% assign tt = t | strip %}{% if tt != blank %}<span class="od-spec-tag">{{ tt }}</span>{% endif %}{% endfor %}
    </div>
    <script>
      // в чипах характеристик делаем жирными числа и префиксы Ø / L (Ø 75, L 300, 24-28, 2.2 ...)
      (function () {
        document.querySelectorAll('.od-spec-tags .od-spec-tag').forEach(function (el) {
          // опциональный Ø или L (лат./кир.) перед числом + само число с дробью и диапазоном
          el.innerHTML = el.textContent.replace(
            /([ØøⵁL]\s*)?(\d+(?:[.,]\d+)?(?:\s*[-–—]\s*\d+(?:[.,]\d+)?)?)/g,
            '<b>$1$2</b>'
          );
        });
      })();
    </script>
    {% endif %}

    {%- comment -%} Метаданные Ø/L для богатой кнопки — из метаполей od-d / od-l (напр. «75 мм» / «300 мм»); пусто — части в кнопке не выводятся {%- endcomment -%}
    <script>
      window.odProductMeta = (function () {
        var m = {
          d: '{{ product.fields.od-d.value | strip | escape }}',
          l: '{{ product.fields.od-l.value | strip | escape }}'
        };
        // метаполя не заполнены — берём из названия: «... 75 L 300» → Ø75 мм / L300 мм
        try {
          var t = '{{ product.title | escape }}';
          var mt = t.match(/(\d{2,3})\s*[LlЛ]\s*(\d{2,3})/);
          if (mt) {
            if (!m.d) m.d = mt[1] + ' мм';
            if (!m.l) m.l = mt[2] + ' мм';
          } else {
            var md = t.match(/дровокола\s+(\d{2,3})/i);
            if (md && !m.d) m.d = md[1] + ' мм';
          }
        } catch (e) {}
        return m;
      })();
    </script>

    {%- comment -%} ЦЕНА + ВАРИАНТЫ + КНОПКА — родной сниппет, не трогаем {%- endcomment -%}
    {% include "product_form" %}

    {%- comment -%} Строка наличия: JS поставит её под ценой и обновит текст по варианту {%- endcomment -%}
    <div class="od-availability js-od-availability">В наличии</div>

    {%- comment -%} Плашка «онлайн −10%»: сумму подставит JS ниже {%- endcomment -%}
    <div class="od-online-badge">
      🔥 При онлайн-оплате — <b class="js-od-online-price"></b> (ещё −10%)
      <span class="od-online-badge__note">При получении — без скидки</span>
    </div>

    {%- comment -%} Вопрос + мессенджеры {%- endcomment -%}
    <div class="od-ask">
      <a class="od-ask__link" href="#contact">Не уверены, что подойдёт? Спросить →</a>
      <div class="od-messengers">
        {%- comment -%} TODO: подставить реальные ссылки {%- endcomment -%}
        <a class="od-msg od-msg--sms" href="sms:+79220352887">SMS</a>
        <a class="od-msg od-msg--tg" href="https://t.me/odrova_ru" target="_blank" rel="noopener">Telegram</a>
        <a class="od-msg od-msg--max" href="#" target="_blank" rel="noopener">MAX</a>
      </div>
      <div class="od-ask__hint">Пришлите фото вала — подберём посадку за 5 минут</div>
    </div>

    {%- comment -%} Скидочные блоки темы (если настроены) {%- endcomment -%}
    {% if block_lists.cart-blocks.blocks.size > 0 %}
    <div class="discount-container cell-12">
      <div class="discount-container-content row">
        {% for block in block_lists.cart-blocks.blocks limit:3 %}
        <div class="discount-card cell-4">
          <span class="result-percent">-&nbsp;{{ block.discount-field }}%</span>
          <div class="discount-info-image"><i class="fa fa-info-circle"></i></div>
          <span class="discount-info-text">{{ block.description-field }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% include "system_insales_widget-calculate_delivery" %}

    {% if product.is_bundle %}
      {% include 'bundle_products' %}
    {% endif %}

    {%- comment -%} Инфо-блок: доставка / оплата / гарантия {%- endcomment -%}
    <div class="od-delivery">
      <div class="od-delivery__item"><b>СДЭК / DPD</b><span>По всей России и СНГ</span></div>
      <div class="od-delivery__item"><b>Ozon Rocket</b><span>Быстрая доставка Ozon</span></div>
      <div class="od-delivery__item"><b>Почта России</b><span>В любой населённый пункт</span></div>
      <div class="od-delivery__item"><b>Оплата при получении</b><span>После осмотра в пункте выдачи</span></div>
      <div class="od-delivery__item"><b>Гарантия 12 мес.</b><span>На весь товар</span></div>
      <div class="od-delivery__item"><b>Урал, Екб</b><span>Верхняя Пышма</span></div>
    </div>

    {%- comment -%} 4 тёмные плитки-преимущества {%- endcomment -%}
    <div class="od-tiles">
      <div class="od-tile">⚙️<span>ЧПУ обработка</span></div>
      <div class="od-tile">💎<span>Сталь 45 + ТВЧ</span></div>
      <div class="od-tile">🔩<span>2 захода резьбы</span></div>
      <div class="od-tile">📦<span>Отправка сегодня</span></div>
    </div>

  </div>{%- comment -%} /.od-product__info {%- endcomment -%}

</div>{%- comment -%} /.od-product {%- endcomment -%}


