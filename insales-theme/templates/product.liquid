<script type="text/javascript">
  $( document ).ready(function() {
    $('.review-manager_reply').each(function() {
      var text = $( this ).text();
      var link; var link_text;
      if (text.includes('http')) {
        if (text.includes('youtu')) {
          var utID = text.split('/').pop();
          link = '<iframe src="//www.youtube.com/embed/'+utID+'" width="560" height="314" allowfullscreen="allowfullscreen"></iframe>'
          link_text = text.split('https://')[0]+link
          $( this ).html(link_text);
        } else {
          link = '<a href="http://'+text.split('://').pop().trim()+'">'+text.split('://').pop().trim()+'</a>'
          link_text = text.split('://')[0].replace("http", "").replace("https", "")+link;
          $( this ).html(link_text);
        }
      }
    });
  });
</script>

<script>
  // Клик по строке рейтинга «★ … · читать» — открыть вкладку «Отзывы» и плавно доскроллить.
  // Якоря #od-reviews-tab в табах нет (сниппет темы не трогаем) — находим вкладку по тексту
  // «Отзыв» среди заголовков табов (.tab-toggle / [data-tab]) и кликаем её.
  $(function () {
    // СТРАХОВКА: InSales кэширует скомпилированный SCSS и не всегда подхватывает
    // правки custom.scss. Чтобы строка рейтинга гарантированно выглядела как нужно,
    // проставляем ВСЕ её стили инлайном на элементы — минуя компиляцию CSS.
    function odIsMobile() { return window.matchMedia('(max-width: 760px)').matches; }
    function odStyleRating() {
      var $rl = $('.js-od-rating-line').first();
      if (!$rl.length) return;
      var mob = odIsMobile();
      // размеры: десктоп крупные, мобила мельче (иначе строка вылезает за экран)
      var starsF = mob ? '1.25rem' : '1.75rem';
      var starsM = mob ? '8px'     : '14px';
      var avgF   = mob ? '1.1rem'  : '1.55rem';
      var sepF   = mob ? '0.9rem'  : '1.15rem';
      var sepM   = mob ? '0 9px'   : '0 16px';
      var txtF   = mob ? '0.95rem' : '1.2rem';
      // на мобиле разрешаем перенос (nowrap убираем), чтобы не вылезало
      $rl.css({
        'display': 'block', 'margin-top': mob ? '14px' : '20px',
        'margin-bottom': mob ? '18px' : '28px',
        'line-height': '1.4', 'white-space': mob ? 'normal' : 'nowrap',
        'text-decoration': 'none', 'font-family': "'PT Sans', sans-serif", 'cursor': 'pointer'
      });
      $rl.children().css({ 'display': 'inline-block', 'vertical-align': 'middle' });
      var starsEl = $rl.find('.od-rating-line__stars').get(0);
      if (starsEl) {
        starsEl.style.setProperty('font-size', starsF, 'important');
        starsEl.style.setProperty('letter-spacing', mob ? '2px' : '3px', 'important');
        starsEl.style.setProperty('color', '#f5c800', 'important');
        starsEl.style.setProperty('-webkit-text-fill-color', '#f5c800', 'important');
        starsEl.style.setProperty('margin-right', starsM, 'important');
      }
      var avgEl = $rl.find('.od-rating-line__avg').get(0);
      if (avgEl) {
        avgEl.style.setProperty('font-size', avgF, 'important');
        avgEl.style.setProperty('font-weight', '700', 'important');
        avgEl.style.setProperty('color', '#111', 'important');
        avgEl.style.setProperty('-webkit-text-fill-color', '#111', 'important');
        avgEl.style.setProperty('line-height', '1', 'important');
      }
      $rl.find('.od-rating-line__sep').css({ 'color': '#c4c4c4', 'font-size': sepF, 'margin': sepM });
      $rl.find('.od-rating-line__count').css({ 'font-size': txtF, 'color': '#555' });
      $rl.find('.od-rating-line__read').css({
        'font-size': txtF, 'font-weight': '700', 'color': '#555', 'border-bottom': '1px solid #999'
      });
    }
    // вызываем несколько раз: тема может перекрашивать звёзды своим JS позже загрузки
    odStyleRating();
    setTimeout(odStyleRating, 300);
    setTimeout(odStyleRating, 800);

    // черта под чипами характеристик (как в прототипе) — серая разделительная линия.
    // Ставим инлайном, т.к. CSS может не доехать из-за кэша компиляции SCSS.
    function odChipsRule() {
      var mob = odIsMobile();
      var chips = document.querySelector('.od-product-page .od-spec-tags');
      if (chips) {
        chips.style.setProperty('padding-bottom', mob ? '14px' : '20px', 'important');
        chips.style.setProperty('border-bottom', '1px solid #e0e0e0', 'important');
        chips.style.setProperty('margin-bottom', mob ? '14px' : '20px', 'important');
        chips.style.setProperty('gap', mob ? '7px' : '12px', 'important');
        chips.querySelectorAll('.od-spec-tag').forEach(function (t) {
          t.style.setProperty('font-size', mob ? '0.8rem' : '0.95rem', 'important');
          t.style.setProperty('padding', mob ? '7px 11px' : '11px 17px', 'important');
        });
      }
      var h1 = document.querySelector('.od-product-page .od-product__title');
      if (h1) {
        h1.style.setProperty('font-size', mob ? '1.55rem' : '2.2rem', 'important');
        h1.style.setProperty('line-height', '1.2', 'important');
      }
      var kicker = document.querySelector('.od-product-page .od-kicker');
      if (kicker) {
        kicker.style.setProperty('font-size', mob ? '0.72rem' : '0.82rem', 'important');
        kicker.style.setProperty('letter-spacing', mob ? '2px' : '2.5px', 'important');
      }
    }
    odChipsRule();
    setTimeout(odChipsRule, 300);
    // пересчёт при ресайзе/повороте экрана
    var odRzT;
    $(window).on('resize orientationchange', function () {
      clearTimeout(odRzT);
      odRzT = setTimeout(function () { odStyleRating(); odChipsRule(); }, 150);
    });
    $(document).on('click', '.js-od-rating-line', function (e) {
      e.preventDefault();
      var $tab = $('.od-product-page .tab-toggle, .od-product-page [data-tab], .od-product-page .tabs-controls a, .od-product-page .tabs-controls button')
        .filter(function () { return /отзыв/i.test($(this).text()); }).first();
      if ($tab.length) {
        $tab.trigger('click');
        $('html,body').animate({ scrollTop: $tab.offset().top - 90 }, 350);
      } else {
        // запасной путь: проскроллить к блоку отзывов, если он на странице
        var $rev = $('.od-product-page .reviews, .od-product-page .product-reviews, .od-product-page .comment_list').first();
        if ($rev.length) $('html,body').animate({ scrollTop: $rev.offset().top - 90 }, 350);
      }
    });
  });
</script>

</div>{%- comment -%} /.od-product-page {%- endcomment -%}
